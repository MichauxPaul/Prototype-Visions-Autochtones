  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizGameManager
  questions:
  - questionText: "Comment s\u2019appelle le territoire ancestral des Innus ?"
    answers:
    - A. Wolastokuk
    - B. Nitassinan
    - C. Eeyou Istchee
    correctAnswerIndex: 1
  - questionText: "Quel animal \xE9tait central dans leur mode de vie traditionnel
      ?"
    answers:
    - A. Le castor
    - B. Le caribou
    - C. Le saumon
    correctAnswerIndex: 1
  - questionText: "Qu\u2019est-ce que le makusham ?"
    answers:
    - A. Un outil de chasse
    - "B. Une danse, un repas et une c\xE9l\xE9bration"
    - "C. Un type d\u2019habitation"
    correctAnswerIndex: 1
  - questionText: "\xC0 quoi servent les piquets dans le travail des peaux ?"
    answers:
    - "A. \xC0 couper la peau"
    - "B. \xC0 la d\xE9corer"
    - "C. \xC0 l\u2019\xE9tirer pour la faire s\xE9cher"
    correctAnswerIndex: 2
  - questionText: "Comment s\u2019appelle la langue des Innus ?"
    answers:
    - A. Inuktitut
    - B. Innu-aimun
    - C. Algonquin
    correctAnswerIndex: 1
